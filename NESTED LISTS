if __name__ == '__main__':
    students = []
    # Read the number of students
    for _ in range(int(input())):
        name = input()
        score = float(input())
        students.append([name, score])

    # Extract all grades and find the second lowest
    grades = sorted(list(set(student[1] for student in students)))
    second_lowest = grades[1]

    # Find names with the second lowest grade and sort alphabetically
    names = [student[0] for student in students if student[1] == second_lowest]
    names.sort()

    # Print results
    for name in names:
        print(name)
