from itertools import combinations

def print_combinations(S, K):
    # Sort the input string S to ensure lexicographic order
    sorted_S = sorted(S)
    
    # Iterate through combination sizes from 1 to K (inclusive)
    for k in range(1, K + 1):
        # Generate combinations of size k from the sorted string
        for combo in combinations(sorted_S, k):
            # Join the tuple into a string and print it
            print("".join(combo))

# Read input from the user
try:
    line = input().split()
    if len(line) == 2:
        S = line[0]
        K = int(line[1])
        print_combinations(S, K)
    else:
        print("Invalid input format. Please provide string S and integer K separated by a space.")
except ValueError:
    print("Invalid input for K. K must be an integer.")
except EOFError:
    pass
