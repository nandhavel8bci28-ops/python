import sys

# Read N and M from standard input
n, m = map(int, input().split())

# Upper pattern
for i in range(1, n, 2):
    print((".|." * i).center(m, "-"))

# Center WELCOME line
print("WELCOME".center(m, "-"))

# Lower pattern (reversed upper)
for i in range(n-2, -1, -2):
    print((".|." * i).center(m, "-"))
